<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Accedi — Gestaway Condomini</title>
<link rel="icon" href="favicon.svg" type="image/svg+xml">
<style>
  :root {
    --bg: #f7f6f3;
    --surface: #ffffff;
    --border: #e5e3dd;
    --text: #1a1a18;
    --muted: #6b6b66;
    --green: #1D9E75;
    --red: #A32D2D;
    --blue: #185FA5;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 36px 32px;
    width: 100%;
    max-width: 360px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
  }
  .brand-mark {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--blue);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 16px;
  }
  .brand-text { font-size: 15px; font-weight: 600; }
  .brand-sub { font-size: 11.5px; color: var(--muted); }
  h1 { font-size: 18px; font-weight: 600; margin-bottom: 6px; }
  p.lead { font-size: 13.5px; color: var(--muted); margin-bottom: 22px; }
  label { display: block; font-size: 12.5px; font-weight: 500; color: var(--muted); margin-bottom: 6px; }
  input {
    width: 100%;
    padding: 10px 12px;
    font-size: 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    outline: none;
    background: var(--bg);
    color: var(--text);
  }
  input:focus { border-color: var(--blue); }
  button {
    width: 100%;
    margin-top: 18px;
    padding: 11px;
    font-size: 14px;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    background: var(--blue);
    color: #fff;
    cursor: pointer;
  }
  button:disabled { opacity: 0.6; cursor: default; }
  .errore {
    margin-top: 14px;
    font-size: 13px;
    color: var(--red);
    background: #FCEBEB;
    padding: 9px 12px;
    border-radius: 7px;
    display: none;
  }
</style>
</head>
<body>

<div class="card">
  <div class="brand">
    <div class="brand-mark">G</div>
    <div>
      <div class="brand-text">Gestaway Condomini</div>
      <div class="brand-sub">Area amministratore</div>
    </div>
  </div>

  <h1>Accedi</h1>
  <p class="lead">Inserisci la password di amministrazione per entrare nel gestionale.</p>

  <form id="form-login">
    <label for="password">Password</label>
    <input type="password" id="password" name="password" autocomplete="current-password" required autofocus>
    <button type="submit" id="btn-login">Accedi</button>
    <div class="errore" id="errore"></div>
  </form>
</div>

<script>
  const form = document.getElementById('form-login');
  const btn = document.getElementById('btn-login');
  const erroreBox = document.getElementById('errore');

  // Se gia' autenticato, vai direttamente al gestionale
  fetch('/api/sessione').then(r => r.json()).then(d => {
    if (d.autenticato) window.location.href = '/gestionale.html';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    erroreBox.style.display = 'none';
    btn.disabled = true;
    btn.textContent = 'Accesso in corso…';

    const password = document.getElementById('password').value;

    try {
      const res = await fetch('/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ password }),
      });
      const dati = await res.json();

      if (res.ok) {
        window.location.href = '/gestionale.html';
      } else {
        erroreBox.textContent = dati.errore || 'Accesso non riuscito.';
        erroreBox.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Accedi';
      }
    } catch (err) {
      erroreBox.textContent = 'Errore di connessione al server.';
      erroreBox.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Accedi';
    }
  });
</script>

</body>
</html>
